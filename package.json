		"@storybook/addon-essentials": "^8.6.0",
		"@storybook/addon-svelte-csf": "^5.0.0",
		"@storybook/sveltekit": "^8.6.0",
		"@storybook/svelte": "^8.6.0",
		"@testing-library/svelte": "^5.0.0",
		"@testing-library/jest-dom": "^6.0.0",
		"@types/three": "^0.172.0",
		"@vitest/ui": "^3.0.0",
		"storybook": "^8.6.0",
		"svelte": "^5.55.2",
